<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verificar 2FA — Auth2FA</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="card">
    <div class="logo">
      <div class="logo-icon">🔐</div>
      <span class="logo-text">Auth2FA</span>
    </div>

    <h1>Verificación 2FA</h1>
    <p class="subtitle">Abre tu app y escribe el código de 6 dígitos</p>

    <% if (error) { %>
      <div class="error-box">⚠️ <%= error %></div>
    <% } %>

    <form method="POST" action="/verify-2fa">
      <div class="form-group">
        <label>Código de verificación</label>
        <input
          type="text"
          name="token"
          placeholder="000000"
          maxlength="6"
          inputmode="numeric"
          autocomplete="one-time-code"
          style="font-size:24px; text-align:center; letter-spacing:0.3em;"
          autofocus
          required
        >
      </div>
      <button class="btn" type="submit">Verificar →</button>
    </form>

    <div class="link-row">
      <a href="/logout">← Cancelar y salir</a>
    </div>
  </div>
</body>
</html>
